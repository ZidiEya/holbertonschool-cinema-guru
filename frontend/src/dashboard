// Importation du fichier CSS spécifique pour le style du tableau de bord (dashboard)
import './dashboard.css';

// Importation du composant Header, généralement utilisé pour l'en-tête de la page (navigation principale, logo, etc.)
import Header from '../../components/navigation/Header';

// Importation du composant SideBar, utilisé pour la navigation latérale dans le dashboard
import SideBar from '../../components/navigation/SideBar';

// Importation des composants de routing de React Router pour gérer la navigation entre les pages du dashboard
import { BrowserRouter, Routes, Route, Navigate } from 'react-router-dom';

// Importation de la page d'accueil du dashboard (vue principale)
import HomePage from './HomePage';

// Importation de la page qui affiche les titres ou contenus favoris de l'utilisateur
import Favorites from './Favorites';

// Importation de la page qui affiche les contenus que l'utilisateur a ajoutés pour regarder plus tard
import WatchLater from './WatchLater';


const Dashboard = ({ userUsername, setIsLoggedIn }) => {

	return (
		<BrowserRouter>
			<div className="dashboard">
				<Header
					userUsername={userUsername}
					setIsLoggedIn={setIsLoggedIn}>
				</Header>
				<div className='main-page'>
				<SideBar></SideBar>
				<Routes>
					<Route path="/home" element={<HomePage />} />
					<Route path="/favorites" element={<Favorites />} />
					<Route path="/watchlater" element={<WatchLater />} />
					<Route path="*" element={<Navigate to="/home" />} />
				</Routes>
				</div>
			</div>
		</BrowserRouter>
	);
};

export default Dashboard;
